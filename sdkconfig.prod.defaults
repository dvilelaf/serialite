# Production profile overlay.
#
# Apply on a clean build with:
#   cp sdkconfig.prod.defaults sdkconfig.defaults.local
#   idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.prod.defaults" build
#
# Never commit the private signing key referenced by CONFIG_SECURE_BOOT_SIGNING_KEY.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_SIGNED_APPS=y
CONFIG_SECURE_SIGNED_ON_UPDATE=y
CONFIG_SECURE_BOOT_V2_ENABLED=y
CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y
CONFIG_SECURE_BOOT_SIGNING_KEY="/run/secrets/esp32-kvm/prod-kvm-signing-key.pem"
CONFIG_SECURE_FLASH_ENC_ENABLED=y
CONFIG_SECURE_FLASH_ENCRYPTION_MODE_RELEASE=y
CONFIG_NVS_ENCRYPTION=y
CONFIG_LOG_DEFAULT_LEVEL_WARN=y
CONFIG_BOOTLOADER_LOG_LEVEL_WARN=y
CONFIG_ESP_SYSTEM_PANIC_SILENT_REBOOT=y
