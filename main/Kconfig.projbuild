menu "ESP32-KVM"

config ESP32_KVM_HTTPS_LOCAL_ENABLE
    bool "Enable local HTTPS listener with on-screen fingerprint"
    default n
    help
        Starts a local HTTPS listener on the rescue AP when a per-boot
        certificate can be generated and its SHA-256 fingerprint is shown on
        the AMOLED. Disabled by default to preserve the simpler HTTP-only
        rescue path unless operators explicitly opt in.

config ESP32_KVM_BLE_PROVISIONING_ENABLE
    bool "Enable gated BLE provisioning runtime"
    default n
    help
        Enables the BLE provisioning runtime gate. This does not replace the
        offline AP flow. The runtime is fail-closed and must not start a BLE
        radio unless physical presence, local pairing, encrypted NVS, and
        bounded time windows are all satisfied.

endmenu
